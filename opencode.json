{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "cors": [
      "{env:OPENCODE_DOMAIN}"
    ]
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#8ea39819eed74fe2a0338e71789f06b30e953041"
  ],
  "permission": {
    "*": "deny",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "skill": "allow",
  },
  "agent": {
    // default agents
    "build": {
      "model": "deepseek/deepseek-chat",
      "permission": {
        "bash": "allow",
        "apply_patch": "allow",
        "edit": "allow",
        "write": "allow"
      }
    },
    "plan": {
      "model": "deepseek/deepseek-chat",
      "permission": {
        "markdown_*": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    // high complex agents
    "creation-orchestrator": {
      "model": "openai/gpt-5.4"
    },
    "feature-lead": {
      "model": "openai/gpt-5.4"
    },
    "debug-lead": {
      "model": "openai/gpt-5.4"
    },
    // medium complex agents
    "reviewer": {
      "model": "minimax/MiniMax-M2.7"
    },
    "feature-manager": {
      "model": "openai/gpt-5.3-codex"
    },
    "discovery": {
      "model": "deepseek/deepseek-reasoner"
    },
    "quick-lead": {
      "model": "minimax/MiniMax-M2.7"
    },
    // low complex agents
    "builder": {
      "model": "openai/gpt-5.4-mini",
      "options": {
        "reasoningEffort": "high"
      }
    },
  },
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
      },
      "timeout": 1200000,
      "enabled": false
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    },
    "sonarqube": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "{env:SONARQUBE_URL}"
      },
      "enabled": false,
      "timeout": 60000
    }
  }
}
